# Runtime
VIDEOGEO_USE_MOCKS=true
VIDEOGEO_MAX_RETRIES_PER_STAGE=2
VIDEOGEO_RENDER_CONCURRENCY=4
VIDEOGEO_VIDEO_CONCURRENCY=2
PYTHONIOENCODING=utf-8

# chorify-ai-service
VIDEOGEO_AI_SERVICE_BASE_URL=http://localhost:8544
VIDEOGEO_INTERNAL_API_KEY=
VIDEOGEO_AI_SERVICE_REPO=../chorify-ai-service
VIDEOGEO_AI_SERVICE_PYTHON=
VIDEOGEO_AI_SERVICE_HTTP_TIMEOUT_SEC=120
VIDEOGEO_AI_SERVICE_VIDEO_POLL_INTERVAL_SEC=8
VIDEOGEO_AI_SERVICE_VIDEO_TIMEOUT_SEC=1800

# Volcano Ark for agent/gate reasoning
VIDEOGEO_VOLCANO_API_URL=https://ark.cn-beijing.volces.com/api/v3
VIDEOGEO_VOLCANO_API_KEY=
VIDEOGEO_VOLCANO_MODEL=
VIDEOGEO_VOLCANO_THINKING_ENABLED=false

# GitHub
GITHUB_ORG=SilentGenesisLab
GITHUB_REPO=videoGEO2
GITHUB_TOKEN=
GIT_HTTP_PROXY=http://127.0.0.1:7888

