# ── 运行模式 ───────────────────────────────────────────────
# true = 全程 mock（MockCapabilities），无需密钥/网络即可端到端跑通
# false = 真实 HTTP 调 chorify-ai-service
VIDEOGEO_USE_MOCKS=true
VIDEOGEO_MAX_RETRIES_PER_STAGE=2
PYTHONIOENCODING=utf-8

# ── chorify-ai-service（媒体能力来源）─────────────────────────
VIDEOGEO_AI_SERVICE_BASE_URL=http://localhost:8544
VIDEOGEO_INTERNAL_API_KEY=
VIDEOGEO_AI_SERVICE_REPO=../chorify-ai-service
VIDEOGEO_AI_SERVICE_PYTHON=
VIDEOGEO_AI_SERVICE_HTTP_TIMEOUT_SEC=120
VIDEOGEO_AI_SERVICE_VIDEO_POLL_INTERVAL_SEC=8
VIDEOGEO_AI_SERVICE_VIDEO_TIMEOUT_SEC=1800

# ── 豆包 Volcano Ark（Agent/门禁推理）────────────────────────
VIDEOGEO_VOLCANO_API_URL=https://ark.cn-beijing.volces.com/api/v3
VIDEOGEO_VOLCANO_API_KEY=
VIDEOGEO_VOLCANO_MODEL=
VIDEOGEO_VOLCANO_THINKING_ENABLED=false

# ── GitHub / Repo ───────────────────────────────────────────
GITHUB_ORG=SilentGenesisLab
GITHUB_REPO=videoGEO2
GITHUB_TOKEN=
GIT_HTTP_PROXY=http://127.0.0.1:7888

# ── Deployment Host ─────────────────────────────────────────
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_PASSWORD=

# ── PostgreSQL / Redis Port Pools ───────────────────────────
POSTGRES_PORT_START=54321
POSTGRES_PORT_END=54399
REDIS_PORT_START=63791
REDIS_PORT_END=63800

# ── Alibaba Cloud OSS ───────────────────────────────────────
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_CUSTOM_DOMAIN=

# ── Feishu Notification ─────────────────────────────────────
FEISHU_WEBHOOK_URL=

# ── Aliyun SMS ──────────────────────────────────────────────
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION_ID=cn-hangzhou
